# Python virtual environments
.venv/
backend/.venv/

# MCMC traces (large binaries, not needed for web deployment)
data/mcmc-traces/

# SRTR raw Excel files
data/srtr-raw/

# SRTR raw archive (153 MB of preserved release zips — kept in git for
# durability, but offline-only: the runtime API loads the parsed JSONs, not
# these. Bundling them blew past Lambda's 500 MB ephemeral limit.)
data/srtr-archive/

# Historical observed-rates (offline temporal-validation input only; the
# runtime loads srtr-observed-rates.json, the current release, not this file)
data/srtr-observed-rates-historical.json

# Model comparison snapshots
data/snapshots/

# Docs site build artifacts
docs-site/build/
docs-site/.docusaurus/
docs-site/node_modules/

# Development files
.claude/
.playwright-mcp/
notebooks/
*.pyc
__pycache__/
.pytest_cache/
.DS_Store
